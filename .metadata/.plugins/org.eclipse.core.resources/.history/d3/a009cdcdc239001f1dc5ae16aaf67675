#include <stdint.h>
#include <GPIOx.h>

void delay(uint32_t c)
{
	while(c--);
}

int main(void)
{
  RCC_EnPort(GPIOB);//configura reloj en puerto B
	GPIOx_InitIO(GPIOB, 13, GPIO_MODER_OUTPUT, false);


    while(1)
    {
		GPIOB->ODR  ^= 0x00002000;// Commute bit 13 with a xor operation
        // delay = 250ms
        delay(200000);
    }
}
